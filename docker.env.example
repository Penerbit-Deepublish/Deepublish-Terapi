NODE_ENV=production
PORT=3000

# Postgres service in docker-compose.easypanel.yml
DATABASE_URL=postgresql://postgres:postgres@db:5432/terapi?schema=terapi

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=12h

ADMIN_EMAIL=admin@terapi.local
ADMIN_PASSWORD=replace-with-strong-password

# true only for first boot if you want initial seed data
SEED_ON_BOOT=false
